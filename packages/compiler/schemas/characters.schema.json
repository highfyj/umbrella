{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vn://schemas/characters",
  "title": "VN 角色注册表（characters.yaml）",
  "type": "object",
  "required": ["characters"],
  "additionalProperties": false,
  "properties": {
    "characters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "voiced": { "type": "boolean", "description": "false = 该角色台词默认不配音" },
          "production": {
            "type": "object",
            "description": "编辑素材（生产元数据）：不进 IR、不随游戏发布",
            "additionalProperties": false,
            "properties": {
              "refs": {
                "type": "array",
                "description": "AI 出图参考立绘（production/refs/ 下的路径）",
                "items": { "type": "string" }
              },
              "tts": {
                "type": "object",
                "description": "TTS 音色配置：参考音频 + 透传给生成接口的参数",
                "additionalProperties": false,
                "properties": {
                  "provider": { "type": "string", "description": "TTS 服务标识（如 gpt-sovits）" },
                  "sample": { "type": "string", "description": "音色参考音频（production/tts/ 下的路径）" },
                  "params": { "type": "object", "description": "透传给 TTS 接口的自由参数" }
                }
              }
            }
          },
          "sprite": {
            "type": "object",
            "required": ["default"],
            "additionalProperties": false,
            "properties": {
              "dims": {
                "type": "object",
                "description": "维度词表：先声明、后出图；脚本用词不在词表中才是错误",
                "additionalProperties": false,
                "properties": {
                  "outfit": { "type": "array", "items": { "type": "string" } },
                  "state": { "type": "array", "items": { "type": "string" } },
                  "face": { "type": "array", "items": { "type": "string" } }
                }
              },
              "default": {
                "type": "object",
                "required": ["outfit", "face"],
                "additionalProperties": false,
                "properties": {
                  "outfit": { "type": "string" },
                  "face": { "type": "string" }
                }
              },
              "variants": {
                "type": "array",
                "description": "整图变体：每条 = 一张完整立绘 + 维度标注；允许为空（占位渲染）",
                "items": {
                  "type": "object",
                  "required": ["outfit", "face", "file"],
                  "additionalProperties": false,
                  "properties": {
                    "outfit": { "type": "string" },
                    "face": { "type": "string" },
                    "state": {
                      "anyOf": [
                        { "type": "string" },
                        { "type": "array", "items": { "type": "string" } }
                      ]
                    },
                    "file": { "type": "string", "description": "相对 sprite/ 的路径" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
