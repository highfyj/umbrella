{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vn://schemas/story",
  "title": "VN 入口文件（story.yaml）",
  "type": "object",
  "required": ["title", "entry"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "description": "游戏标题" },
    "version": { "type": "string" },
    "entry": { "type": "string", "description": "入口场景 id" },
    "vars": {
      "type": "object",
      "description": "变量声明与默认值；使用未声明变量是编译错误",
      "additionalProperties": { "type": ["number", "boolean", "string"] }
    },
    "endings": {
      "type": "object",
      "description": "结局注册表",
      "additionalProperties": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": { "title": { "type": "string" } }
      }
    },
    "currency": {
      "type": "object",
      "description": "货币系统；启用后内置变量 money 可用，并在玩家界面常驻显示",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "description": "缺省视为启用；显式 false 关闭" },
        "name": { "type": "string" },
        "symbol": { "type": "string", "description": "金额前缀符号，如 ¥ / ₲" },
        "initial": { "type": "number", "description": "开局初始金额" }
      }
    }
  }
}
